---
import GithubLogo from '@/assets/icons/github.svg'
import Preview from '@/assets/icons/preview.svg'
import ProjectItemStackBadge from '@/components/base/ProjectItemStackBadge.astro'
import SocialPill from '@/components/base/SocialPill.astro'
import { type ImageMetadata } from 'astro'
import type { ComponentProps } from 'astro/types'
import { Image } from 'astro:assets'

interface Props {
  imageUrl: ImageMetadata;
  title: string;
  stack: ComponentProps<typeof ProjectItemStackBadge>[];
  description: string;
  codeUrl: string;
  previewUrl?: string;
}

const { imageUrl, stack, codeUrl, description, title, previewUrl } =
  Astro.props;
---

<article class="flex flex-col md:flex-row gap-8 group">
  <div
    class="md:flex-1/2 rounded-xl md:rounded-2xl overflow-hidden group-hover:ring-gray-700  group-hover:ring-3 transition-shadow duration-500 h-[350px] md:h-56"
  >
    <Image
      src={imageUrl}
      alt={`${title} Project - Image`}
      class="w-full h-full group-hover:scale-[110%] transition-transform duration-500 object-cover"
      layout="constrained"
      fit="cover"
    />
  </div>

  <div class="md:flex-1/2 md:self-center">
    <h4 class="text-white font-bold text-2xl">{title}</h4>
    <ul class="flex gap-2 rounded mt-3">
      {
        stack.map((s) => (
          <li>
            <ProjectItemStackBadge
              icon={s.icon}
              name={s.name}
              class={s.class}
            />
          </li>
        ))
      }
    </ul>

    <p class="text-gray-400 mt-4">{description}</p>

    <div class="mt-4 space-x-2">
      <SocialPill href={codeUrl}>
        <GithubLogo slot="icon" />
        Code
      </SocialPill>

      {
        previewUrl && (
          <SocialPill href={previewUrl}>
            <Preview slot="icon" />
            Preview
          </SocialPill>
        )
      }
    </div>
  </div>
</article>
