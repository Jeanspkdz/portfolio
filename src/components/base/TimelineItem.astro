---
interface Props {
  date: string;
  title: string;
  description: string;
  class?: string;
}

const { date, title, description, class: className, ...attrs } = Astro.props;
---

<li class:list={['p-4 md:p-8', className]} {...attrs}>
  <div class="absolute w-3 h-3 bg-amber-400 rounded-full mt-1.5 -start-1.5">
  </div>
  <div class="flex flex-col md:flex-row gap-12">
    <div class="md:flex-5/12">
      <h3 class="text-xl font-semibold text-yellow-400">{title}</h3>
      <time
        class="text-sm leading-none font-bold text-white"
        >{date}</time
      >
    </div>
    <div class="md:flex-7/12">
      <p class="mb-4 text-base font-normal text-gray-300">{description}</p>
    </div>
  </div>
</li>

<style></style>
