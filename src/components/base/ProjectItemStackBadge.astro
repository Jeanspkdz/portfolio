---
import type { SvgComponent } from 'astro/types'

interface Props {
  icon: SvgComponent;
  name: string;
  class?: string;
}

const { icon: Icon, name, class: className, ...rest } = Astro.props;
---

<span class:list={['flex items-center gap-1 rounded-full px-2 py-1 text-xs', className]} {...rest}>
  <Icon width={16} height={16} />
  {name}
</span>
