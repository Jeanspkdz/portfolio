---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'a'> {
}
const { href, ...attrs } = Astro.props

---

<a
  class=" focus-visible:ring-amber-400/75 focus-visible:ring-2 inline-flex items-center justify-center gap-2 px-4 py-1  transition border rounded-full bg-gray-800 border-gray-600 text-white text-md hover:bg-gray-100 hover:border-gray-300 hover:text-black group max-w-fit focus:outline-none focus-visible:outline-none focus-visible:ring-offset-2 active:bg-black"
  target="_blank"
  href={href}
  {...attrs}
>
  <slot name="icon" />
  <slot />
</a>
