---
import type { SvgComponent } from 'astro/types'

interface Props {
  icon: SvgComponent;
  title: string;
}

const { icon: Icon, title } = Astro.props;
---

<div class="flex items-center gap-2 text-white font-bold mb-12">
  <h2 class="text-3xl">{title}</h2>
  <Icon class="-order-1" width={35} height={35} />
</div>
