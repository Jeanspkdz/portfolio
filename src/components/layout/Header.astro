---
import MenuIcon from '@/assets/icons/menu.svg'

export type SectionId = 'hero' | 'about' | 'timeline' | 'projects'
type SectionIdString = `#${SectionId}`

type NavItem = {
  href: SectionIdString;
  label: string;
}

const navItems = [
  { href: '#hero', label: 'Home' },
  { href: '#timeline', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#about', label: 'About Me' },
] satisfies NavItem[];
---

<header
  class="z-50 fixed top-0 left-0 right-0 w-full px-6 md:px-16 py-4 pb-6 flex items-center justify-between"
>
  <a
    href="/"
    class="text-white font-mono font-bold tracking-widest uppercase text-sm"
  >
    JEANPKDZ
  </a>

  <!-- Desktop nav -->
  <nav class="hidden md:block" id="desktop-menu">
    <ul class="flex gap-8">
      {
        navItems.map((navItem) => (
          <li>
            <a
              href={navItem.href}
              class="text-gray-400 hover:text-white text-sm tracking-wide transition-colors duration-200"
            >
              {navItem.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Hamburger button -->
  <button
    id="menu-toggle"
    type="button"
    class="md:hidden text-gray-400 hover:text-white focus:outline-none"
    aria-controls="mobile-menu"
    aria-expanded="false"
  >
    <span class="sr-only">Open main menu</span>
    <MenuIcon />
  </button>

  <!-- Mobile nav -->
  <nav
    id="mobile-menu"
    class="hidden absolute top-full left-0 right-0 mx-auto mt-4
  w-11/12 px-6 py-6
  bg-slate-900
  border border-slate-700
  rounded-2xl shadow-xl md:hidden"
  >
    <ul class="flex flex-col gap-3">
      {
        navItems.map((navItem) => (
          <li>
            <a
              href={navItem.href}
              class="block px-4 py-2 rounded-lg
          text-gray-300 hover:text-white
          hover:bg-slate-800
          transition-colors duration-200"
            >
              {navItem.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
const toggle = document.getElementById('menu-toggle')
const menu = document.getElementById('mobile-menu')

toggle?.addEventListener('click', () => {
  const isExpanded = toggle.getAttribute('aria-expanded') === 'true'
  toggle.setAttribute('aria-expanded', String(!isExpanded))
  menu?.classList.toggle('hidden')
})
</script>

<style>
  @reference "tailwindcss";

  header {
    animation: nav-scroll auto linear forwards;
    animation-timeline: scroll(root block);
    animation-range: 100px 300px;

    &:has(#menu-toggle[aria-expanded="true"]) {
      background-color: var(--color-gray-900);
    }
  }

  nav#mobile-menu {
    @supports (scroll-target-group: auto) {
      scroll-target-group: auto;

      & a:target-current {
        color: var(--color-white);
        background-color: var(--color-slate-800);
      }
    }
  }

  nav#desktop-menu {
    position: relative;

    @supports (scroll-target-group: auto) {
      scroll-target-group: auto;

      &::after {
        transition-property:
          top, width, position, display, left, background-color;
        transition-duration: 300ms;
        transition-timing-function: ease-in-out;
        transition-behavior: allow-discrete;
        width: 0px;
        display: none;
        content: " ";
        position: absolute;
        height: 3px;
      }

      &:has(li:not(:first-child) a:target-current)::after {
        display: block;
        content: " ";
        position-anchor: --active-section;
        position: absolute;
        top: calc(anchor(bottom) + 5px);
        left: anchor(left);
        width: calc(anchor-size(width) / 2);
        background-color: var(--color-blue-500);

        @starting-style {
          width: 0px;
        }
      }

      & li:first-child {
        display: none;
      }

      & a:is(:target-current, :hover) {
        @apply text-blue-500;
      }

      & a:target-current {
        anchor-name: --active-section;
      }
    }

    /* & a[href="#projects"] {
      animation: paint auto forwards ;
      animation-timeline: --project-section;
    } */
  }

  @keyframes nav-scroll {
    to {
      background-color: var(--color-gray-900);
      box-shadow: 0 8px 20px 0 rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(var(--blur));
    }
  }

  @keyframes paint {
    to {
      color: var(--color-blue-500);
    }
  }
</style>
