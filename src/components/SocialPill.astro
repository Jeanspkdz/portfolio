---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'a'> {
}
const { href, ...attrs } = Astro.props

---

<a
  class="bg-gray-100 focus-visible:ring-amber-400/75 focus-visible:ring-2 inline-flex items-center justify-center gap-2 px-4 py-1 text-gray-800 transition border border-gray-300 rounded-full dark:bg-gray-800 dark:border-gray-600 dark:text-white text-md hover:bg-gray-900 hover:border-gray-700 hover:text-white dark:hover:bg-gray-100 dark:hover:border-gray-300 dark:hover:text-black group max-w-fit focus:outline-none focus-visible:outline-none focus-visible:ring-offset-2 active:bg-black"
  target="_blank"
  href={href}
  {...attrs}
>
  <slot name="icon" />
  <slot />
</a>
