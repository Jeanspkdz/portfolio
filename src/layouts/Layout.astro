---
import '@/styles/global.css'
import Header from '@/components/layout/Header.astro'
import Footer from '@components/layout/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Jeanpkdz - Portfolio</title>
    <meta name="title" content="Jeanpkdz - Junior Full Stack Developer" />
    <meta
      name="description"
      content="Junior Full Stack Developer and Systems Engineering graduate from Peru. Check out my portfolio and personal projects built with Vue, Nuxt, React and Node.js."
    />
    <meta name="author" content="Jeanpkdz" />
    <meta
      name="keywords"
      content="Jeanpkdz, Full Stack Developer, Junior Developer, Web Developer, Programmer, Software Engineer, Vue, Nuxt, React, Next.js, Node.js"
    />
  </head>
  <body
    class="w-full min-h-dvh h-full bg-gray-950
      bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))] bg-no-repeat"
  >
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>

  <style>
    :root {
      color-scheme: light dark;
    }
    html,
    body {
      margin: 0;
    }

    html {
      scroll-behavior: smooth;
    }
  </style>
</html>
